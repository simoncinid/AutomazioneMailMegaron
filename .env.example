# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Database — nomi classici oppure alias Render (DB_HOST, DB_PORT, …)
DATABASE_HOST=your-db-host.db.ondigitalocean.com
DATABASE_PORT=25060
DATABASE_NAME=defaultdb
DATABASE_USER=doadmin
DATABASE_PASSWORD=your-password
DATABASE_SSL=true

# DB_HOST=...
# DB_PORT=5432
# DB_NAME=...
# DB_USER=...
# DB_PASSWORD=...
# TLS_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# (se imposti TLS_CERT, SSL verso il DB è abilitato automaticamente)

# CA certificate content - paste the full PEM certificate string here
# When DATABASE_SSL=true, this is required for secure connection
CA_FILE="-----BEGIN CERTIFICATE-----
...your DigitalOcean CA certificate...
-----END CERTIFICATE-----"

# Cron - daily import at 03:00 (cron expression)
CRON_IMPORT_SCHEDULE=0 3 * * *

# Admin - token for manual import endpoints
MANUAL_IMPORT_TOKEN=your-secret-admin-token
